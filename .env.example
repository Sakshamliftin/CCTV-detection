# PostgreSQL
POSTGRES_USER=storeiq
POSTGRES_PASSWORD=storeiq_secret
POSTGRES_DB=storeiq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://storeiq:storeiq_secret@postgres:5432/storeiq

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_STORE_EVENTS_TOPIC=store_events
KAFKA_ANOMALY_EVENTS_TOPIC=anomaly_events

# Vision
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_DEVICE=cpu
ENABLE_SIMULATOR=false
SIMULATOR_INTERVAL=2.0
VISION_PORT=8001

# Backend
BACKEND_PORT=8000
ANALYTICS_SNAPSHOT_INTERVAL=30
OVERCROWDING_THRESHOLD=0.9
DWELL_TIME_THRESHOLD=300
TRAFFIC_SPIKE_WINDOW=300
TRAFFIC_SPIKE_THRESHOLD=20

# Frontend
VITE_API_URL=http://localhost:8000
